{
  "extends": [
    "development"
  ],
  "hints": {
    "axe/forms": [
      "default",
      {
        "label": "off"
      }
    ],
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "backdrop-filter"
        ]
      }
    ]
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not and_chr <= 138",
    "not chrome <= 138",
    "not edge <= 138",
    "not firefox <= 140",
    "not safari <= 18.5",
    "not samsung <= 28"
  ]
}